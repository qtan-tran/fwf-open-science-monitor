# ─────────────────────────────────────────────────────────────────────────────
# FWF Open Science Monitor — environment variables
#
# Copy this file to .env and fill in the values:
#   macOS / Linux:          cp .env.example .env
#   Windows (PowerShell):   Copy-Item .env.example .env
#
# .env is never committed to version control (it is in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
#
# Local development (matches docker-compose.yml):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fwf_monitor
#
# When running inside Docker Compose, the web and etl containers override this
# automatically to use the internal service hostname:
#   DATABASE_URL=postgresql://postgres:postgres@db:5432/fwf_monitor
#
# Production examples:
#   Neon:     postgresql://user:password@ep-xyz.neon.tech/fwf_monitor?sslmode=require
#   Supabase: postgresql://postgres:password@db.xyz.supabase.co:5432/postgres
#   Railway:  postgresql://postgres:password@containers-us-west-1.railway.app:PORT/railway


# ─────────────────────────────────────────────────────────────────────────────
# FWF OPEN RESEARCH API  (ETL only)
# ─────────────────────────────────────────────────────────────────────────────

# Base URL for the FWF Open Research API.
# Default is the public production endpoint — only change this if you are
# running a local Meilisearch mirror for development.
FWF_API_URL=https://openapi.fwf.ac.at

# API key for the FWF Open Research API.
# Required to run the ETL pipeline. Not needed to browse the dashboard.
#
# Get a free key (self-service) at:
#   https://openapi.fwf.ac.at/fwfkey
#
# The key is passed as a Bearer token in the Authorization header.
FWF_API_KEY=<your-api-key-here>


# ─────────────────────────────────────────────────────────────────────────────
# NEXT.JS WEB APP
# ─────────────────────────────────────────────────────────────────────────────

# Public base URL of the web app.
# Used for generating absolute URLs (e.g. in Open Graph meta tags).
# Must NOT have a trailing slash.
#
# Local development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
#
# Production:
#   NEXT_PUBLIC_APP_URL=https://your-project.vercel.app


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — only needed for specific features
# ─────────────────────────────────────────────────────────────────────────────

# (Phase 2) Unpaywall API contact email.
# Required if you enable real OA status lookups via the Unpaywall API.
# Unpaywall is free and requires only an email address as identification.
# UNPAYWALL_EMAIL=you@example.com

# (Phase 5) Transactional email service API key.
# Required if you enable scheduled PDF report delivery.
# RESEND_API_KEY=re_...

# (Phase 6) Secret used to sign API keys issued to third-party integrations.
# Generate with: openssl rand -hex 32
# API_KEY_SECRET=
