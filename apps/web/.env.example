# ─────────────────────────────────────────────────────────────────────────────
# FWF Open Science Monitor — Web App Environment Variables
#
# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# On Vercel: add these in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# DATABASE  (required)
# ─────────────────────────────────────────────────────────────────────────────

# Pooled connection string used by Prisma at runtime.
#
# Neon (pooled / pgBouncer endpoint):
#   postgresql://user:password@ep-xxx-yyy.pooler.neon.tech/dbname?sslmode=require&pgbouncer=true
# Supabase (Transaction pooler, port 6543):
#   postgresql://postgres.xxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# Local:
#   postgresql://postgres:postgres@localhost:5432/fwf_monitor
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fwf_monitor

# Direct (non-pooled) connection — required by Prisma Migrate / db push.
# Must NOT go through pgBouncer.
#
# Neon (direct / non-pooled endpoint):
#   postgresql://user:password@ep-xxx-yyy.neon.tech/dbname?sslmode=require
# Supabase (direct connection, port 5432):
#   postgresql://postgres.xxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# Local: same as DATABASE_URL (local Postgres is always a direct connection)
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/fwf_monitor


# ─────────────────────────────────────────────────────────────────────────────
# PUBLIC VARIABLES  (exposed to the browser via Next.js)
# ─────────────────────────────────────────────────────────────────────────────

# Absolute base URL of this deployment — used by Server Components when they
# call the internal API routes (api-client.ts runs server-side on cold starts).
# Must NOT have a trailing slash.
#
# Local:
#   NEXT_PUBLIC_API_BASE=http://localhost:3000
# Vercel (set automatically via VERCEL_URL, or enter manually):
#   NEXT_PUBLIC_API_BASE=https://your-project.vercel.app
NEXT_PUBLIC_API_BASE=http://localhost:3000
